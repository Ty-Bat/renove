---
import { siteData, withBase } from '../data/site';

const pathname = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Accueil' },
  { href: '/realisations/', label: 'Realisations' },
  { href: '/services/', label: 'Services' },
  { href: '/contact/', label: 'Contact' },
];
---

<header class="site-header">
  <div class="site-header-inner">
    <a class="brand-lockup" href={withBase('/')}>
      <span class="brand-mark">Ty Bat</span>
      <span class="brand-subtitle">Renovation interieure</span>
    </a>

    <div class="site-header-actions">
      <nav class="site-nav" aria-label="Navigation principale">
        {navItems.map((item) => (
          <a href={withBase(item.href)} aria-current={pathname === withBase(item.href) ? 'page' : undefined}>
            {item.label}
          </a>
        ))}
      </nav>

      <a class="header-phone" href={siteData.phoneHref} data-plausible-event="click_phone" data-plausible-context="header">
        {siteData.phoneDisplay}
      </a>
    </div>
  </div>
</header>
