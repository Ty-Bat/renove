---
import type { CollectionEntry } from 'astro:content';
import PictureBlock from './PictureBlock.astro';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props as Props;
const projectSlug = project.id.replace(/\.md$/, '');
---

<article class="project-card">
  <div class="media-frame">
    <PictureBlock
      src={project.data.heroImage}
      alt={project.data.heroAlt}
      sizes="(min-width: 1100px) 30vw, (min-width: 760px) 45vw, 92vw"
      loading="lazy"
    />
  </div>

  <div class="project-card-body">
    <span class="eyebrow">{project.data.category}</span>
    <h3>{project.data.title}</h3>
    <p>{project.data.summary}</p>

    <ul class="chip-list" aria-label="Perimetre du chantier">
      {project.data.scope.slice(0, 3).map((item) => (
        <li class="chip">{item}</li>
      ))}
    </ul>

    <footer>
      <span>{project.data.location}</span>
      <a class="text-link" href={`/realisations/${projectSlug}/`} data-plausible-event="project_cta_click" data-plausible-context="project-card" data-plausible-project={project.data.title}>
        Voir le projet
      </a>
    </footer>
  </div>
</article>
