---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PictureBlock from '../../components/PictureBlock.astro';
import ProjectGallery from '../../components/ProjectGallery.astro';
import {
  buildAbsoluteUrl,
  buildProjectWhatsappMessage,
  buildWhatsappHref,
} from '../../data/site';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id.replace(/\.md$/, '') },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const projectSlug = project.id.replace(/\.md$/, '');

const beforeImages = project.data.beforeImages;
const afterImages = project.data.afterImages;
const extraImages = project.data.galleryImages;
const whatsappHref = buildWhatsappHref(buildProjectWhatsappMessage(project.data.title));
const pageUrl = buildAbsoluteUrl(`/realisations/${projectSlug}/`);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: project.data.title,
  description: project.data.summary,
  image: project.data.heroImage.src,
  url: pageUrl,
};

const relatedProjects = (await getCollection('projects'))
  .filter((entry) => entry.id !== project.id)
  .sort((a, b) => a.data.featuredOrder - b.data.featuredOrder)
  .slice(0, 2);
---

<Layout
  title={project.data.title}
  description={project.data.summary}
  image={project.data.heroImage.src}
  canonical={pageUrl}
  schema={schema}
>
  <section class="page-hero section">
    <div class="project-hero">
      <article class="panel stack">
        <span class="eyebrow">{project.data.category}</span>
        <h1 class="page-title">{project.data.title}</h1>
        <p class="page-lead">{project.data.summary}</p>

        <ul class="chip-list" aria-label="Perimetre du chantier">
          {project.data.scope.map((item) => (
            <li class="chip">{item}</li>
          ))}
        </ul>

        <div class="button-row">
          <a
            class="button button-primary"
            href={whatsappHref}
            target="_blank"
            rel="noreferrer"
            data-plausible-event="click_whatsapp"
            data-plausible-context="project-page"
            data-plausible-project={project.data.title}
          >
            Parler de ce projet
          </a>
          <a class="button button-secondary" href="/contact/">
            Voir la page contact
          </a>
        </div>

        <ul class="info-list">
          <li class="chip">{project.data.location}</li>
          <li class="chip">{project.data.completion}</li>
        </ul>
      </article>

      <div class="media-frame">
        <PictureBlock
          src={project.data.heroImage}
          alt={project.data.heroAlt}
          sizes="(min-width: 1050px) 48vw, 92vw"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <section class="section page-frame">
    <div class="two-column">
      <article class="panel content-prose">
        <span class="eyebrow">Le chantier</span>
        <Content />
      </article>

      <article class="panel stack">
        <span class="eyebrow">Resultat</span>
        <h2>Ce que cette renovation apporte</h2>
        <ul>
          {project.data.results.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </article>
    </div>
  </section>

  <section class="section page-frame">
    {beforeImages.length > 0 ? (
      <ProjectGallery title="Avant chantier" images={beforeImages} label="Avant" />
    ) : (
      <article class="notice-card">
        <strong>Avant chantier indisponible</strong>
        <p>
          Ce projet est presente comme chantier livre. La structure de page reste compatible avec un vrai format avant /
          apres si des visuels d etat initial sont ajoutes plus tard.
        </p>
      </article>
    )}

    {afterImages.length > 0 && (
      <ProjectGallery title="Apres livraison" images={afterImages} label="Apres" />
    )}

    {extraImages.length > 0 && (
      <ProjectGallery title="Details et angles complementaires" images={extraImages} label="Galerie" />
    )}
  </section>

  <section class="section">
    <div class="section-header">
      <span class="eyebrow">Autres projets</span>
      <h2>Explorer d autres ambiances de renovation.</h2>
    </div>

    <div class="project-grid">
      {relatedProjects.map((entry) => (
        <article class="project-card">
          <div class="media-frame">
            <PictureBlock
              src={entry.data.heroImage}
              alt={entry.data.heroAlt}
              sizes="(min-width: 1100px) 30vw, (min-width: 760px) 45vw, 92vw"
            />
          </div>
          <div class="project-card-body">
            <span class="eyebrow">{entry.data.category}</span>
            <h3>{entry.data.title}</h3>
            <p>{entry.data.summary}</p>
            <footer>
              <span>{entry.data.location}</span>
              <a class="text-link" href={`/realisations/${entry.id.replace(/\.md$/, '')}/`} data-plausible-event="project_cta_click" data-plausible-context="related-project" data-plausible-project={entry.data.title}>
                Voir le projet
              </a>
            </footer>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
