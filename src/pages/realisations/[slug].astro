---
import { getCollection, render } from 'astro:content';
import type { ImageMetadata } from 'astro';
import Layout from '../../layouts/Layout.astro';
import PictureBlock from '../../components/PictureBlock.astro';
import ProjectSequence from '../../components/ProjectSequence.astro';
import {
  buildAbsoluteUrl,
  buildProjectWhatsappMessage,
  buildWhatsappHref,
  withBase,
} from '../../data/site';

type PhotoGroup = {
  label: string;
  title: string;
  text: string;
  images: ImageMetadata[];
};

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id.replace(/\.md$/, '') },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const projectSlug = project.id.replace(/\.md$/, '');

const fallbackGroups: PhotoGroup[] = [
  project.data.beforeImages.length > 0
    ? {
        label: 'Etat initial',
        title: 'Visuels avant chantier',
        text: 'Premiers reperes photographiques avant intervention.',
        images: project.data.beforeImages,
      }
    : null,
  project.data.afterImages.length > 0
    ? {
        label: 'Resultat',
        title: 'Photos apres livraison',
        text: 'Lecture du rendu final et de la piece terminee.',
        images: project.data.afterImages,
      }
    : null,
  project.data.galleryImages.length > 0
    ? {
        label: 'Details',
        title: 'Complements et vues de detail',
        text: 'Vues complementaires pour montrer les finitions et l usage.',
        images: project.data.galleryImages,
      }
    : null,
].filter((item): item is PhotoGroup => item !== null);

const photoGroups: PhotoGroup[] =
  project.data.photoGroups.length > 0 ? project.data.photoGroups : fallbackGroups;

const whatsappHref = buildWhatsappHref(buildProjectWhatsappMessage(project.data.title));
const pageUrl = buildAbsoluteUrl(`/realisations/${projectSlug}/`);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: project.data.title,
  description: project.data.summary,
  image: project.data.heroImage.src,
  url: pageUrl,
};

const relatedProjects = (await getCollection('projects'))
  .filter((entry) => entry.id !== project.id)
  .sort((a, b) => a.data.featuredOrder - b.data.featuredOrder)
  .slice(0, 2);
---

<Layout
  title={project.data.title}
  description={project.data.summary}
  image={project.data.heroImage.src}
  canonical={pageUrl}
  schema={schema}
>
  <section class="section project-page-hero">
    <div class="project-page-copy">
      <span class="eyebrow">{project.data.category}</span>
      <h1 class="page-title">{project.data.title}</h1>
      <p class="page-lead">{project.data.summary}</p>

      <ul class="chip-list" aria-label="Perimetre du chantier">
        {project.data.scope.map((item) => (
          <li class="chip">{item}</li>
        ))}
      </ul>

      <div class="button-row">
        <a
          class="button button-primary"
          href={whatsappHref}
          target="_blank"
          rel="noreferrer"
          data-plausible-event="click_whatsapp"
          data-plausible-context="project-page"
          data-plausible-project={project.data.title}
        >
          Parler de ce chantier
        </a>
        <a class="button button-secondary" href={withBase('/contact/')}>
          Voir la page contact
        </a>
      </div>
    </div>

    <div class="project-page-stage">
      <div class="project-stage-media">
        <PictureBlock
          src={project.data.heroImage}
          alt={project.data.heroAlt}
          sizes="(min-width: 1100px) 40vw, 92vw"
          loading="eager"
        />
      </div>

      <aside class="project-stage-panel">
        <div class="project-facts">
          <span class="eyebrow">Repere</span>
          <ul class="info-list">
            <li class="chip">{project.data.location}</li>
            <li class="chip">{project.data.completion}</li>
          </ul>
        </div>

        <div class="project-facts">
          <strong>Ce que ce chantier change</strong>
          <ul class="result-list">
            {project.data.results.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <section class="section project-story-grid">
    <article class="story-card content-prose">
      <span class="eyebrow">Le chantier</span>
      <Content />
    </article>

    <article class="story-card">
      <span class="eyebrow">Lecture du projet</span>
      <h2>Des sous-sections pour montrer ce qui a ete fait, pas seulement le rendu final.</h2>
      <p>
        Cette fiche regroupe les photos par type d action realisee. Le but est de voir rapidement l avant, le changement de
        volume, puis les details qui finissent le chantier.
      </p>
      <ol class="sequence-outline">
        {photoGroups.map((group) => (
          <li>
            <strong>{group.label}</strong>
            <span>{group.title}</span>
          </li>
        ))}
      </ol>
    </article>
  </section>

  <section class="section sequence-flow">
    {photoGroups.map((group, index) => (
      <ProjectSequence
        label={group.label}
        title={group.title}
        text={group.text}
        images={group.images}
        reverse={index % 2 === 1}
      />
    ))}
  </section>

  <section class="section related-section">
    <div class="section-header">
      <span class="eyebrow">Autres chantiers</span>
      <h2>Poursuivre avec d autres typologies de renovation.</h2>
    </div>

    <div class="project-grid">
      {relatedProjects.map((entry) => (
        <article class="project-card">
          <div class="project-card-head">
            <span class="eyebrow">{entry.data.category}</span>
            <span class="project-card-order">0{entry.data.featuredOrder}</span>
          </div>
          <div class="media-frame project-card-media">
            <PictureBlock
              src={entry.data.heroImage}
              alt={entry.data.heroAlt}
              sizes="(min-width: 1100px) 30vw, (min-width: 760px) 45vw, 92vw"
            />
          </div>
          <div class="project-card-body">
            <h3>{entry.data.title}</h3>
            <p>{entry.data.summary}</p>
            <footer>
              <span>{entry.data.location}</span>
              <a
                class="text-link"
                href={withBase(`/realisations/${entry.id.replace(/\.md$/, '')}/`)}
                data-plausible-event="project_cta_click"
                data-plausible-context="related-project"
                data-plausible-project={entry.data.title}
              >
                Voir le projet
              </a>
            </footer>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
