---
import { getCollection } from 'astro:content';
import PictureBlock from '../components/PictureBlock.astro';
import Layout from '../layouts/Layout.astro';
import {
  buildAbsoluteUrl,
  buildProjectWhatsappMessage,
  buildWhatsappHref,
  siteData,
  withBase,
} from '../data/site';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.featuredOrder - b.data.featuredOrder,
);

const leadProject = projects[0];
const supportProject = projects[1] ?? leadProject;
const transformationProject =
  projects.find((project) => project.data.beforeImages.length > 0) ?? leadProject;

const showcaseProjects = projects.map((project) => ({
  project,
  sequenceCards:
    project.data.photoGroups.length > 0
      ? project.data.photoGroups.slice(0, 3).map((group) => ({
          label: group.label,
          title: group.title,
          image: group.images[0],
        }))
      : project.data.afterImages.slice(0, 3).map((image, index) => ({
          label: `Vue ${index + 1}`,
          title: project.data.title,
          image,
        })),
}));

const transformationBefore =
  transformationProject.data.beforeImages[0] ??
  transformationProject.data.photoGroups[0]?.images[0] ??
  transformationProject.data.heroImage;

const transformationAfter =
  transformationProject.data.afterImages[0] ??
  transformationProject.data.photoGroups[1]?.images[0] ??
  transformationProject.data.heroImage;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Accueil Ty Bat',
  url: buildAbsoluteUrl('/'),
  description: siteData.description,
};
---

<Layout
  title="Renovation interieure a Morlaix"
  description={siteData.description}
  image={leadProject.data.heroImage.src}
  canonical={buildAbsoluteUrl('/')}
  schema={schema}
>
  <section class="landing-hero section">
    <div class="hero-copy">
      <span class="eyebrow">Ty Bat • Morlaix et Finistere nord</span>
      <p class="hero-kicker">Renovation interieure</p>
      <h1 class="hero-title">Des chantiers propres a regarder, simples a comprendre et solides a vivre.</h1>
      <p class="hero-lead">
        Ty Bat remet les volumes en ordre, clarifie les usages et livre des finitions nettes sur les salles de bain,
        cuisines, arriere-cuisines et reprises de second oeuvre.
      </p>

      <div class="button-row">
        <a
          class="button button-primary"
          href={buildWhatsappHref(buildProjectWhatsappMessage())}
          target="_blank"
          rel="noreferrer"
          data-plausible-event="click_whatsapp"
          data-plausible-context="hero"
        >
          Demarrer sur WhatsApp
        </a>
        <a
          class="button button-secondary"
          href={siteData.phoneHref}
          data-plausible-event="click_phone"
          data-plausible-context="hero"
        >
          Appeler Ty Bat
        </a>
      </div>

      <div class="hero-ledger">
        <article class="ledger-card">
          <span>Approche</span>
          <strong>Un seul interlocuteur du premier repere jusqu'a la livraison.</strong>
        </article>
        <article class="ledger-card">
          <span>Portfolio</span>
          <strong>Chaque chantier est raconte en vues d'ensemble, transformation et details.</strong>
        </article>
        <article class="ledger-card">
          <span>Zone</span>
          <strong>{siteData.serviceAreaLabel}</strong>
        </article>
      </div>
    </div>

    <div class="hero-stage">
      <article class="hero-stage-main">
        <div class="hero-stage-media">
          <PictureBlock
            src={leadProject.data.heroImage}
            alt={leadProject.data.heroAlt}
            sizes="(min-width: 1100px) 36vw, 92vw"
            loading="eager"
          />
        </div>
        <div class="hero-stage-caption">
          <span>{leadProject.data.category}</span>
          <strong>{leadProject.data.title}</strong>
          <p>{leadProject.data.summary}</p>
        </div>
      </article>

      <div class="hero-stage-stack">
        <article class="hero-note-card">
          <span class="eyebrow">Lecture chantier</span>
          <h2>Des fiches organisees par sequence d intervention.</h2>
          <p>
            Chaque projet met en evidence l etat initial, les transformations visibles et les photos de detail, pour mieux
            montrer ce qui a vraiment ete realise.
          </p>
          <ul class="mini-list">
            {leadProject.data.photoGroups.slice(0, 3).map((group) => (
              <li>{group.label}</li>
            ))}
          </ul>
        </article>

        <article class="hero-support-card">
          <div class="hero-support-media">
            <PictureBlock
              src={supportProject.data.heroImage}
              alt={supportProject.data.heroAlt}
              sizes="(min-width: 1100px) 16vw, 92vw"
            />
          </div>
          <div class="hero-support-copy">
            <span>{supportProject.data.category}</span>
            <strong>{supportProject.data.title}</strong>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <span class="eyebrow">Signature</span>
      <h2>Une renovation qui garde le chantier lisible et le rendu final propre.</h2>
      <p class="page-lead">
        Le site prend le parti du concret: plus de matiere, plus de photos utiles, moins de promesses vagues. On comprend
        vite le type d intervention, l ambiance livree et le niveau de finition.
      </p>
    </div>

    <div class="signature-grid">
      {siteData.differentiators.map((item) => (
        <article class="signature-card">
          <span class="signature-index">{item.title}</span>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section transformation-band">
    <div class="section-header">
      <span class="eyebrow">Avant / apres</span>
      <h2>Un chantier de transformation complete pour voir la methode en un coup d oeil.</h2>
    </div>

    <div class="before-after-layout">
      <figure class="before-after-card">
        <div class="before-after-media">
          <PictureBlock
            src={transformationBefore}
            alt={`Etat initial du projet ${transformationProject.data.title}`}
            sizes="(min-width: 1100px) 24vw, 92vw"
          />
        </div>
        <figcaption>Etat initial</figcaption>
      </figure>

      <figure class="before-after-card">
        <div class="before-after-media">
          <PictureBlock
            src={transformationAfter}
            alt={`Resultat final du projet ${transformationProject.data.title}`}
            sizes="(min-width: 1100px) 24vw, 92vw"
          />
        </div>
        <figcaption>Resultat livre</figcaption>
      </figure>

      <article class="before-after-note">
        <span class="eyebrow">Projet repere</span>
        <h3>{transformationProject.data.title}</h3>
        <p>{transformationProject.data.summary}</p>
        <ul class="chip-list" aria-label="Points clefs du projet">
          {transformationProject.data.scope.map((item) => (
            <li class="chip">{item}</li>
          ))}
        </ul>
        <a class="button button-secondary" href={withBase(`/realisations/${transformationProject.id.replace(/\.md$/, '')}/`)}>
          Voir la fiche complete
        </a>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <span class="eyebrow">Portfolio</span>
      <h2>Trois chantiers, trois ambiances, une meme logique de finition.</h2>
    </div>

    <div class="showcase-list">
      {showcaseProjects.map(({ project, sequenceCards }, index) => (
        <article class:list={['showcase-card', index % 2 === 1 && 'is-reversed']}>
          <div class="showcase-copy">
            <span class="eyebrow">{project.data.category}</span>
            <h3>{project.data.title}</h3>
            <p>{project.data.summary}</p>

            <ul class="chip-list" aria-label={`Travaux presents pour ${project.data.title}`}>
              {project.data.scope.map((item) => (
                <li class="chip">{item}</li>
              ))}
            </ul>

            <div class="showcase-links">
              <a
                class="button button-secondary"
                href={withBase(`/realisations/${project.id.replace(/\.md$/, '')}/`)}
                data-plausible-event="project_cta_click"
                data-plausible-context="home-showcase"
                data-plausible-project={project.data.title}
              >
                Explorer ce chantier
              </a>
              <span class="showcase-meta">{project.data.location}</span>
            </div>
          </div>

          <div class="showcase-media">
            <div class="showcase-main-image">
              <PictureBlock
                src={project.data.heroImage}
                alt={project.data.heroAlt}
                sizes="(min-width: 1100px) 33vw, 92vw"
              />
            </div>

            <div class="showcase-sections">
              {sequenceCards.map((item) => (
                <article class="sequence-teaser">
                  <div class="sequence-teaser-media">
                    <PictureBlock
                      src={item.image}
                      alt={item.title}
                      sizes="(min-width: 1100px) 8vw, 28vw"
                    />
                  </div>
                  <div class="sequence-teaser-copy">
                    <span>{item.label}</span>
                    <strong>{item.title}</strong>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <span class="eyebrow">Prestations</span>
      <h2>Un site pense pour montrer le geste de chantier autant que le resultat livre.</h2>
    </div>

    <div class="service-grid">
      {siteData.services.map((service) => (
        <article class="service-card">
          <h3>{service.title}</h3>
          <p>{service.summary}</p>
          <ul class="chip-list" aria-label={`Prestations ${service.title}`}>
            {service.items.map((item) => (
              <li class="chip">{item}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section process-section">
    <div class="section-header">
      <span class="eyebrow">Methode</span>
      <h2>Un parcours court, clair et facile a suivre pour le client.</h2>
    </div>

    <div class="process-grid">
      {siteData.process.map((item) => (
        <article class="process-card">
          <div class="step">{item.step}</div>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="cta-panel">
      <div>
        <span class="eyebrow">Prise de contact</span>
        <h2>Appel direct ou message WhatsApp pour envoyer les premieres photos du chantier.</h2>
      </div>
      <div class="button-row">
        <a
          class="button button-primary"
          href={buildWhatsappHref(buildProjectWhatsappMessage())}
          target="_blank"
          rel="noreferrer"
          data-plausible-event="click_whatsapp"
          data-plausible-context="home-final-cta"
        >
          Envoyer un message
        </a>
        <a
          class="button button-secondary"
          href={siteData.phoneHref}
          data-plausible-event="click_phone"
          data-plausible-context="home-final-cta"
        >
          {siteData.phoneDisplay}
        </a>
      </div>
    </div>
  </section>
</Layout>
